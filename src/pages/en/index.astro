---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { solutionPagesEn, industryPagesEn } from "../../data/detailPagesEn";
const phases = [["Enter","Start with the free Telco audit or a specific requirement."],["Design","Build the right network mix and business case from your data."],["Deploy","Activate hardware, networks, and AIr Connect without interruption."],["Manage and expand","Monitor, optimize, and scale as your footprint changes."]];
const pillars = [["Business continuity, always on by design","SuperWAN combines independent networks and technologies into a multi-network resilience layer."],["Proactive 24/7 management","Our owned NOC monitors every site; AIr Connect gives you consolidated visibility."],["Telco as a Service","We audit and restructure the full telecom stack, then govern it continuously."]];
---
<BaseLayout title="Business continuity for distributed enterprises in Mexico | Vialterna" description="Vialterna delivers multi-network resilience, managed SD-WAN, Telco as a Service, and IoT/SIM solutions across Mexico." lang="en">
  <Header lang="en" />
  <main>
    <section class="hero"><div class="shell hero-grid"><div class="hero-content"><div class="eyebrow reveal">For Mexican enterprises where downtime has a measurable cost.</div><h1 class="reveal">Networks break. <span class="accent">Your business does not.</span></h1><p class="hero-copy reveal">Vialterna is the multi-network resilience layer for large distributed enterprises in Mexico. We combine networks and technologies into one always-on architecture, monitored 24/7 and backed by SLA. We do not sell a link. We deliver uptime.</p><div class="actions"><a class="button primary" href="/en/telco-audit/">Get your free Telco audit</a><a class="button" href="/en/contact/">Talk to an expert</a></div><p>We respond within one business day. Free. No commitment.</p></div><div class="network-scene" aria-hidden="true"><div class="orbit orbit-outer"><i></i><i></i><i></i><i></i></div><div class="orbit orbit-middle"></div><div class="orbit orbit-inner"></div><div class="network-center"><strong>NOC</strong><span>24 / 7</span></div></div></div></section>
    <section class="detail-strip"><div class="shell detail-strip-grid"><div><strong>+2,500</strong><span>sites and devices monitored</span></div><div><strong>99.97%+</strong><span>availability by contract</span></div><div><strong>15+ years</strong><span>critical infrastructure in Mexico</span></div></div></section>
    <section class="section risk" id="model"><div class="shell"><div class="kicker">The reframe</div><h2 class="risk-title">Connectivity is not a utility. <span class="accent">It is operational risk.</span></h2><p class="risk-lead">When a site goes offline, revenue stops, teams return to manual processes, and SLA disputes begin. The bill is not the cost. The downtime is.</p><h3 class="approaches-title">You likely run one of two setups. Both leave you exposed.</h3><div class="approaches"><article class="approach"><div class="number">01</div><h3>SD-WAN on a single network</h3><p>Traffic is managed, but the underlying network remains a single point of failure and per-site firewalls inflate cost.</p></article><article class="approach"><div class="number">02</div><h3>Commodity internet without management</h3><p>No SLA, monitoring, or failover means downtime is absorbed silently across the estate.</p></article></div></div></section>
    <section class="section pillars-section"><div class="shell"><div class="kicker">The Vialterna model</div><h2>We do not sell connectivity. We engineer uptime.</h2><p class="section-intro">Network and technology independent by design. Your providers remain in the architecture; we add resilience, management, and accountability above them.</p><div class="pillars">{pillars.map((p,i)=><article class="pillar"><div class="pillar-number">0{i+1}</div><h3>{p[0]}</h3><p>{p[1]}</p></article>)}</div></div></section>
    <section class="section phases-section"><div class="shell"><div class="kicker">How we engage</div><h2>One platform. One engagement. Four phases.</h2><div class="phases">{phases.map((p,i)=><article class="phase"><span>0{i+1}</span><h3>{p[0]}</h3><p>{p[1]}</p></article>)}</div></div></section>
    <section class="section solutions-section" id="solutions"><div class="shell"><div class="section-head"><div class="kicker">Four solutions</div><div><h2>Four solutions. One platform.</h2><p class="section-intro">Whatever it takes to keep your operations online.</p></div></div><div class="editorial-list">{solutionPagesEn.map((s,i)=><article><span>0{i+1}</span><h2><a href={`/en/solutions/${s.slug}/`}>{s.title}</a></h2><p>{s.description}</p></article>)}</div></div></section>
    <section class="section industries-section" id="industries"><div class="shell"><div class="section-head"><div class="kicker">Who it is for</div><div><h2>Built for distributed operations where downtime has a price tag.</h2></div></div><div class="industries">{industryPagesEn.map((s,i)=><a class="industry" href={`/en/industries/${s.slug}/`}><div class="industry-orbit"></div><span>0{i+1}</span><h3>{s.title}</h3><p>{s.description}</p></a>)}</div></div></section>
    <section class="section detail-benefits"><div class="shell detail-benefits-grid"><div><div class="kicker">Proof</div><h2>Our clients do not leave. They grow with us.</h2></div><ul><li>+2,500 managed sites and devices</li><li>99.97%+ Edge availability</li><li>15+ years in Mexico</li><li>Nationwide ER Network coverage</li></ul></div></section>
    <section class="cta-section"><div class="shell"><div class="kicker">Start with a diagnostic</div><h2>Find the risk and cost hidden in your telecom stack.</h2><p>Receive a written report, quantified TCO comparison, and a specific architecture recommendation.</p><div class="actions"><a class="button primary" href="/en/telco-audit/">Get your free Telco audit</a><a class="button" href="/en/contact/">Talk to an expert</a></div><p>We respond within one business day. Free. No commitment.</p></div></section>
  </main>
  <Footer lang="en" />
</BaseLayout>
