---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
---
<BaseLayout title="Resilient enterprise connectivity in Mexico | Vialterna" description="Vialterna designs, deploys and operates managed connectivity for distributed enterprises in Mexico.">
  <main>
    <section class="detail-hero">
      <div class="shell detail-hero-grid">
        <div>
          <a class="brand" href="/en/" aria-label="Vialterna home"><img class="brand-logo" src="/brand/vialterna-logo-white.svg" alt="Vialterna" width="168" height="50" /></a>
          <div class="eyebrow" style="margin-top: 70px">Critical infrastructure in Mexico</div>
          <h1 class="detail-title">Availability as a Service for distributed operations.</h1>
          <p class="detail-lead">Carrier-agnostic, multi-network architecture delivered as a managed service for companies where a disconnected site has a measurable cost.</p>
          <div class="actions"><a class="button primary" href="mailto:atencionaclientes@vialterna.com">Talk to an expert</a><a class="button" href="/">ES</a></div>
        </div>
        <div class="detail-network" aria-hidden="true"><i></i><i></i><i></i><span>NOC<br />24 / 7</span></div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
