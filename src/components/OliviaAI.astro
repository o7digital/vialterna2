<div class="olivia" data-olivia>
  <section class="olivia__panel" hidden>
    <header><div><strong>o7 Olivia AI</strong><small data-subtitle>Asistente Vialterna · En línea</small></div><button data-close aria-label="Cerrar">×</button></header>
    <div class="olivia__messages" data-messages><p class="bot" data-welcome>Hola, soy o7 Olivia AI. ¿Cómo puedo ayudarte con la conectividad de tu empresa?</p></div>
    <form data-form>
      <label><input type="checkbox" data-consent required /> <span data-consent-label>Acepto compartir mis datos para recibir atención de Vialterna.</span></label>
      <div><input data-input required placeholder="Escribe tu pregunta…" /><button data-send>Enviar</button></div>
    </form>
  </section>
  <button class="olivia__teaser" data-open><b>O</b><span data-teaser>¿Necesitas ayuda?</span></button>
</div>

<script>
  const root = document.querySelector("[data-olivia]");
  const panel = root?.querySelector(".olivia__panel");
  const open = root?.querySelector("[data-open]");
  const close = root?.querySelector("[data-close]");
  const form = root?.querySelector("[data-form]");
  const input = root?.querySelector<HTMLInputElement>("[data-input]");
  const messages = root?.querySelector("[data-messages]");
  const english = document.documentElement.lang.toLowerCase().startsWith("en");
  const copy = english ? {
    subtitle: "Vialterna Assistant · Online",
    welcome: "Hello, I’m o7 Olivia AI. How can I help with your company’s connectivity?",
    consent: "I agree to share my data to receive assistance from Vialterna.",
    placeholder: "Write your question…", send: "Send", teaser: "Need help?",
    fallback: "I’m unable to answer right now. Email us at atencionaclientes@vialterna.com."
  } : {
    subtitle: "Asistente Vialterna · En línea",
    welcome: "Hola, soy o7 Olivia AI. ¿Cómo puedo ayudarte con la conectividad de tu empresa?",
    consent: "Acepto compartir mis datos para recibir atención de Vialterna.",
    placeholder: "Escribe tu pregunta…", send: "Enviar", teaser: "¿Necesitas ayuda?",
    fallback: "No pude responder ahora. Escríbenos a atencionaclientes@vialterna.com."
  };
  const setText = (selector: string, value: string) => {
    const element = root?.querySelector(selector);
    if (element) element.textContent = value;
  };
  setText("[data-subtitle]", copy.subtitle);
  setText("[data-welcome]", copy.welcome);
  setText("[data-consent-label]", copy.consent);
  setText("[data-teaser]", copy.teaser);
  setText("[data-send]", copy.send);
  if (input) input.placeholder = copy.placeholder;
  open?.addEventListener("click", () => { panel?.removeAttribute("hidden"); open.setAttribute("hidden", ""); });
  close?.addEventListener("click", () => { panel?.setAttribute("hidden", ""); open?.removeAttribute("hidden"); });
  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const message = input?.value.trim();
    if (!message || !messages || !input) return;
    messages.insertAdjacentHTML("beforeend", `<p class="user">${message.replaceAll("<", "&lt;")}</p>`);
    input.value = "";
    const pending = document.createElement("p"); pending.className = "bot"; pending.textContent = "…"; messages.append(pending);
    try {
      const response = await fetch("https://www.o7digital.com/api/o7-chat", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message, language: english ? "en" : "es", siteCode: "vialterna" })
      });
      const data = await response.json();
      pending.textContent = data.reply || "Un asesor Vialterna continuará contigo.";
    } catch { pending.textContent = copy.fallback; }
    messages.scrollTop = messages.scrollHeight;
  });
</script>

<style>
  .olivia{position:fixed;right:24px;bottom:24px;z-index:9999;font:14px/1.4 Inter,sans-serif}.olivia__teaser{display:flex;align-items:center;gap:10px;padding:10px 15px;border:1px solid #28d7c0;border-radius:999px;background:#071d2b;color:#fff;box-shadow:0 14px 38px #0005}.olivia__teaser b{display:grid;place-items:center;width:32px;height:32px;border-radius:50%;background:#28d7c0;color:#071d2b}.olivia__panel{width:min(380px,calc(100vw - 28px));overflow:hidden;border:1px solid #28d7c066;border-radius:16px;background:#071d2b;color:#fff;box-shadow:0 20px 60px #0007}.olivia__panel header{display:flex;justify-content:space-between;padding:16px;background:#0b2c3d}.olivia__panel small{display:block;color:#9bc7cf}.olivia__panel button{border:0;border-radius:8px;background:#28d7c0;color:#071d2b;font-weight:700}.olivia__messages{height:260px;overflow:auto;padding:14px;background:#f4f8f9;color:#122}.olivia__messages p{max-width:85%;padding:9px 11px;border-radius:12px;background:#fff}.olivia__messages .user{margin-left:auto;background:#d8faf5}.olivia form{padding:12px}.olivia label{display:flex;gap:7px;font-size:11px;color:#c5d7dc}.olivia form div{display:flex;gap:8px;margin-top:10px}.olivia form input[data-input]{min-width:0;flex:1;padding:11px;border:0;border-radius:8px}@media(max-width:560px){.olivia{right:14px;bottom:14px}}
</style>
