---
import { navigation } from "../data/site";
interface Props { lang?: "es" | "en" }
const { lang = "es" } = Astro.props;
const isEnglish = lang === "en";
const items = isEnglish ? [
  { label: "Solutions", href: "/en/#solutions" },
  { label: "Industries", href: "/en/#industries" },
  { label: "Company", href: "/en/empresa/" },
  { label: "Insights", href: "/en/insights/" },
  { label: "FAQ", href: "/en/faq/" },
  { label: "Contact", href: "/en/contacto/" }
] : navigation;
---
<header class="header" data-header>
  <div class="shell header-inner">
    <a class="brand" href={isEnglish ? "/en/" : "/"} aria-label={isEnglish ? "Vialterna home" : "Vialterna inicio"}>
      <img class="brand-logo" src="/brand/vialterna-logo-white.svg" alt="Vialterna" width="168" height="50" />
    </a>
    <button class="menu-button" type="button" aria-label="Abrir menú" aria-expanded="false" data-menu-button>
      <span></span><span></span>
    </button>
    <nav class="nav-links" aria-label="Navegación principal" data-menu>
      {items.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="language-link" href={isEnglish ? "/" : "/en/"} lang={isEnglish ? "es" : "en"}>{isEnglish ? "ES" : "EN"}</a>
    </nav>
    <a class="button primary header-cta" href={isEnglish ? "/en/contacto/" : "/contacto/"}>{isEnglish ? "Talk to an expert" : "Habla con un experto"} <span aria-hidden="true">↗</span></a>
  </div>
</header>
