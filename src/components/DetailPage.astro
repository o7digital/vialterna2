---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import type { DetailPage as DetailPageData } from "../data/detailPages";

interface Props { page: DetailPageData; lang?: "es" | "en" }
const { page, lang = "es" } = Astro.props;
const en = lang === "en";
---
<BaseLayout title={`${page.title} | Vialterna`} description={page.description} lang={en ? "en" : "es-MX"}>
  <Header lang={lang} />
  <main>
    <section class="detail-hero">
      <div class="shell detail-hero-grid">
        <div>
          <div class="eyebrow reveal">{page.eyebrow}</div>
          <h1 class="detail-title reveal">{page.title}</h1>
          <p class="detail-lead reveal">{page.description}</p>
          <a class="button primary reveal" href={en ? "/en/contacto/" : "/contacto/"}>{en ? "Talk to an expert" : "Habla con un experto"}</a>
        </div>
        <div class="detail-network" aria-hidden="true"><i></i><i></i><i></i><span>NOC<br />24 / 7</span></div>
      </div>
    </section>

    <section class="detail-strip">
      <div class="shell detail-strip-grid">
        <div><strong>Multioperador</strong><span>Arquitectura flexible</span></div>
        <div><strong>SLA</strong><span>Disponibilidad respaldada</span></div>
        <div><strong>Respaldo</strong><span>Continuidad operativa</span></div>
      </div>
    </section>

    {page.problem && (
      <section class="section detail-problem">
        <div class="shell detail-copy">
          <div class="kicker reveal">{en ? "Operational risk" : "Riesgo operativo"}</div>
          <h2 class="reveal">{page.problemTitle}</h2>
          <p class="reveal">{page.problem}</p>
        </div>
      </section>
    )}

    <section class="section detail-includes">
      <div class="shell">
        <div class="kicker reveal">{en ? "Managed service" : "Gestión administrada"}</div>
        <h2 class="detail-section-title reveal">{page.sectionTitle}</h2>
        <div class="detail-items">
          {page.items.map((item, index) => (
            <article class="detail-item reveal">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section detail-benefits">
      <div class="shell detail-benefits-grid">
        <div>
          <div class="kicker reveal">{en ? "Benefits" : "Beneficios"}</div>
          <h2 class="reveal">{en ? "Availability designed around your operation." : "Disponibilidad diseñada alrededor de tu operación."}</h2>
        </div>
        <ul class="reveal">
          {page.benefits.map((benefit) => <li>{benefit}</li>)}
        </ul>
      </div>
    </section>

    <section class="cta-section" id="contacto">
      <div class="shell reveal">
        <div class="kicker">{en ? "Assessment" : "Diagnóstico"}</div>
        <h2>{en ? "Start with a connectivity assessment." : "Empieza con un diagnóstico de conectividad."}</h2>
        <p>{en ? "We analyze infrastructure, contracts, redundancy and performance to identify risk and optimization opportunities." : "Analizamos infraestructura, contratos, redundancias y desempeño para identificar riesgos y oportunidades de optimización."}</p>
        <a class="button primary" href="mailto:atencionaclientes@vialterna.com">{en ? "Talk to an expert" : "Habla con un experto"}</a>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
