---
interface Props { lang?: "es" | "en" }
const { lang = "es" } = Astro.props;
const en = lang === "en";
---
<footer>
  <div class="shell footer-main">
    <div>
      <a class="brand" href={en ? "/en/" : "/"} aria-label="Vialterna"><img class="brand-logo" src="/brand/vialterna-logo-white.svg" alt="Vialterna" width="168" height="50" /></a>
      <p>{en ? "Resilient connectivity" : "Conectividad resiliente"}</p>
    </div>
    <div>
      <h4>{en ? "Solutions" : "Soluciones"}</h4>
      <a href={`${en ? "/en" : ""}/soluciones/conectividad-sitios-distribuidos/`}>{en ? "Edge Solutions" : "Soluciones Edge"}</a>
      <a href={`${en ? "/en" : ""}/soluciones/sitios-centrales/`}>{en ? "Central Sites" : "Sitios centrales"}</a>
      <a href={`${en ? "/en" : ""}/soluciones/iot-sim-administradas/`}>{en ? "IoT/SIM Solutions" : "Soluciones IoT/SIM"}</a>
      <a href={`${en ? "/en" : ""}/soluciones/respaldo-satelital-celular/`}>{en ? "Backup Solutions" : "Soluciones de Respaldo"}</a>
    </div>
    <div>
      <h4>{en ? "Company" : "Empresa"}</h4>
      <a href={`${en ? "/en" : ""}/industrias/`}>{en ? "Industries" : "Industrias"}</a>
      <a href={`${en ? "/en" : ""}/empresa/`}>{en ? "Company" : "Empresa"}</a>
      <a href={`${en ? "/en" : ""}/insights/`}>{en ? "Insights" : "Noticias"}</a>
      <a href={`${en ? "/en" : ""}/faq/`}>FAQ</a>
      <a href={`${en ? "/en" : ""}/aviso-de-privacidad/`}>{en ? "Privacy notice" : "Aviso de privacidad"}</a>
    </div>
    <div>
      <h4>{en ? "Contact" : "Contacto"}</h4>
      <a href="mailto:atencionaclientes@vialterna.com">atencionaclientes@vialterna.com</a>
      <a href="https://wa.me/525580626884">+52 55 8062 6884</a>
      <a href="https://www.linkedin.com/company/vialterna/">LinkedIn</a>
    </div>
  </div>
  <div class="shell footer-bottom"><span>© 2026 Vialterna</span><span>Montes Urales 720 · Lomas de Chapultepec · CDMX 11000</span></div>
</footer>
