---
interface Props { lang?: "es" | "en" }
const { lang = "es" } = Astro.props;
const en = lang === "en";
---
<footer>
  <div class="shell footer-main">
    <div>
      <a class="brand" href={en ? "/en/" : "/"} aria-label="Vialterna"><img class="brand-logo" src="/brand/vialterna-logo-white.svg" alt="Vialterna" width="168" height="50" /></a>
      <p>{en ? "Resilient connectivity" : "Conectividad resiliente"}</p>
    </div>
    <div>
      <h4>{en ? "Solutions" : "Soluciones"}</h4>
      {en ? <>
        <a href="/en/solutions/edge/">Edge / SuperWAN</a>
        <a href="/en/solutions/core/">Core</a>
        <a href="/en/solutions/telco-as-a-service/">Telco as a Service</a>
        <a href="/en/solutions/iot-sim/">IoT and SIM</a>
      </> : <>
        <a href="/soluciones/edge/">Soluciones Edge</a>
        <a href="/soluciones/core/">Core</a>
        <a href="/soluciones/telco-as-a-service/">Telco as a Service</a>
        <a href="/soluciones/iot-sim/">Soluciones IoT/SIM</a>
      </>}
    </div>
    <div>
      <h4>{en ? "Industries" : "Empresa"}</h4>
      {en ? <>
        <a href="/en/industries/financial-services/">Financial Services</a>
        <a href="/en/industries/retail-franchise/">Retail and Franchise Chains</a>
        <a href="/en/industries/energy-industrial/">Energy and Industrial</a>
        <a href="/en/industries/payments-infrastructure/">Payments Infrastructure</a>
        <a href="/en/industries/logistics-cold-chain/">Logistics and Cold Chain</a>
      </> : <>
        <a href="/industrias/">Industrias</a>
        <a href="/empresa/">Empresa</a>
        <a href="/insights/">Noticias</a>
        <a href="/faq/">FAQ</a>
        <a href="/aviso-de-privacidad/">Aviso de privacidad</a>
      </>}
    </div>
    <div>
      <h4>{en ? "Contact" : "Contacto"}</h4>
      <a href="mailto:atencionaclientes@vialterna.com">atencionaclientes@vialterna.com</a>
      <a href="https://wa.me/525580626884">+52 55 8062 6884</a>
      <a href="https://www.linkedin.com/company/vialterna/">LinkedIn</a>
    </div>
  </div>
  <div class="shell footer-bottom">
    <span>© 2026 Vialterna</span>
    <span>Montes Urales 720 · Lomas de Chapultepec · CDMX 11000</span>
    <a class="back-to-top" href="#top">
      {en ? "Back to top" : "Volver arriba"}
      <span aria-hidden="true">↑</span>
    </a>
  </div>
</footer>
